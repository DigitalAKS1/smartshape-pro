# Copy this to .env and fill in your values

# MongoDB Atlas (get from atlas.mongodb.com)
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=smartshape_prod

# Auth — generate a strong random string (64+ chars)
JWT_SECRET=change-this-to-a-long-random-secret

# Admin account created on first startup
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=change-this-strong-password

# Frontend URL (set after Netlify deploy)
FRONTEND_URL=https://your-app.netlify.app

# Optional — Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
