# ── Copy this to .env.evolution and fill in your values ──────────────────────
# NEVER commit the actual .env.evolution to git.

# ── Residential Proxy (required for WhatsApp QR on VPS) ──────────────────────
# Tor (free) is blocked by WhatsApp. Buy a residential SOCKS5 proxy:
#   SmartProxy  → https://smartproxy.com  (~$2.50/GB, port 10001)
#   ProxyScrape → https://proxyscrape.com (~$2/GB,    port 6000)
#   BrightData  → https://brightdata.com  (~$10/GB,   port 22225)
#
# After buying, fill these in and run:
#   docker compose -f docker-compose.evolution.yml up -d --force-recreate tor-sidecar
#
PROXY_HOST=
PROXY_PORT=10001
PROXY_USER=
PROXY_PASS=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# ── Evolution API ─────────────────────────────────────────────────────────────
# Public URL Evolution API is reachable at (your VPS IP or domain)
SERVER_URL=http://YOUR_VPS_IP:8080

# API key — set this same value in your FastAPI .env as EVOLUTION_API_KEY
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=smartshape_evolution_key_CHANGE_ME
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# ── Database (matches postgres service above) ─────────────────────────────────
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:change_me_strong_password@postgres:5432/evolution
DATABASE_CONNECTION_CLIENT_NAME=evolution_api
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true

# ── Redis cache ───────────────────────────────────────────────────────────────
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/6
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ── QR Code ───────────────────────────────────────────────────────────────────
QRCODE_LIMIT=40
QRCODE_COLOR=#e94560

# ── Webhook (points to your FastAPI backend) ──────────────────────────────────
# SmartShape listens at /api/webhooks/whatsapp
WEBHOOK_GLOBAL_ENABLED=true
WEBHOOK_GLOBAL_URL=http://YOUR_VPS_IP:8000/api/webhooks/whatsapp
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true
WEBHOOK_GLOBAL_WEBHOOK_BASE64=false

# Events to forward (only status-relevant ones)
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_SET=false
WEBHOOK_EVENTS_MESSAGES_UPSERT=false
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_MESSAGES_DELETE=false
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_EVENTS_CONTACTS_SET=false
WEBHOOK_EVENTS_CONTACTS_UPSERT=false
WEBHOOK_EVENTS_CONTACTS_UPDATE=false
WEBHOOK_EVENTS_PRESENCE_UPDATE=false
WEBHOOK_EVENTS_CHATS_SET=false
WEBHOOK_EVENTS_CHATS_UPSERT=false
WEBHOOK_EVENTS_CHATS_UPDATE=false
WEBHOOK_EVENTS_CHATS_DELETE=false
WEBHOOK_EVENTS_GROUPS_UPSERT=false
WEBHOOK_EVENTS_GROUP_UPDATE=false
WEBHOOK_EVENTS_GROUP_PARTICIPANTS_UPDATE=false
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_ERRORS=true

# ── Runtime ───────────────────────────────────────────────────────────────────
DEL_INSTANCE=false
LOG_LEVEL=ERROR
LOG_COLOR=true
LOG_BAILEYS=error
NODE_ENV=production

# ── FastAPI .env additions (add these to your existing backend .env) ──────────
# EVOLUTION_API_URL=http://YOUR_VPS_IP:8080
# EVOLUTION_API_KEY=smartshape_evolution_key_CHANGE_ME
# WHATSAPP_INSTANCE=smartshape
# PUBLIC_BASE_URL=http://YOUR_VPS_IP:8000
# WA_SEND_DELAY_SECONDS=3
# ANTHROPIC_API_KEY=sk-ant-...
