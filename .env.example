# =============================================
# SmartShape App — Environment Variables
# Copy this file to backend/.env and fill in
# =============================================

# --- MongoDB ---
MONGO_URL=mongodb://mongodb:27017/smartshape_prod
# For local dev (no Docker): MONGO_URL=mongodb://localhost:27017/smartshape_dev

# --- JWT Auth ---
JWT_SECRET=replace_with_64_char_random_string_use_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Admin Seed Credentials (created on first startup) ---
ADMIN_EMAIL=info@smartshape.in
ADMIN_PASSWORD=ChangeMeSecurely!

# --- Frontend URL (used for CORS + catalogue links) ---
FRONTEND_URL=https://yourdomain.com

# --- Gmail SMTP (for sending quotations, reimbursement emails) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourapp@gmail.com
SMTP_PASSWORD=your_gmail_app_password

# --- WhatsApp Integration (messageautosender.com) ---
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_API_URL=https://api.messageautosender.com/v1

# --- Google OAuth (via Emergent Agent proxy) ---
GOOGLE_CLIENT_ID=your_google_client_id

# --- File Storage (Emergent object store) ---
STORAGE_BASE_URL=your_emergent_storage_url

# --- Stripe (payment processing, Phase 6C) ---
STRIPE_SECRET_KEY=sk_live_xxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxx

# =============================================
# frontend/.env — React build-time variables
# =============================================
REACT_APP_BACKEND_URL=https://yourdomain.com
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=false
